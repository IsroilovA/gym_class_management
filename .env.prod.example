# .env.prod.example — Production environment template
#
# Copy to .env.prod and fill in real values:
#   cp .env.prod.example .env.prod
#
# NEVER commit .env.prod (it is gitignored).
#
# Start production stack:
#   docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up -d --build

# Django
ENVIRONMENT=production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=<generate-a-strong-secret-key>
DEBUG=False
# Set this to your real domain(s) and server IP.
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,your-server-ip

# Database — used by both Django and docker-compose (Postgres container).
# Use strong, unique values. Never reuse dev credentials.
DB_NAME=gym_db_prod
DB_USER=gym_user_prod
DB_PASSWORD=<generate-a-strong-password>
DB_HOST=db
DB_PORT=5432

# Certbot / Let's Encrypt
# Registration email used by Let's Encrypt.
CERTBOT_EMAIL=you@example.com
# Comma-separated domains for one SAN cert (apex first = canonical cert name).
CERTBOT_DOMAINS=17102gymclasses.app,www.17102gymclasses.app
# 1 = Let's Encrypt staging (testing), 0 = production CA.
CERTBOT_STAGING=0

# Gunicorn (all optional — sensible defaults in gunicorn.conf.py)
# Auto workers are capped by GUNICORN_MAX_WORKERS to avoid OOM in small containers.
# GUNICORN_MAX_WORKERS=3
# GUNICORN_WORKERS=2  # Explicit override (takes precedence over auto/cap)
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info
